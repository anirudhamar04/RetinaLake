# ============================================
# Database Configuration
# ============================================
# PostgreSQL connection settings
# Prefix: DB_
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=chaksudb
DB_USER=chaksuai
DB_PASSWORD=chaksuai   # must match POSTGRES_PASSWORD in docker-compose.yml

# Connection pool settings
DB_MIN_CONNECTIONS=4
DB_MAX_CONNECTIONS=200

# ============================================
# Storage Configuration
# ============================================
# Root directories for file storage
# Prefix: STORAGE_
STORAGE_LOCAL_ROOT=./data/processed


STORAGE_DATA_ROOT=./data/raw

# ============================================
# Logging Configuration
# ============================================
# Logging settings
# Prefix: LOG_
LOG_LEVEL=DEBUG
LOG_FORMAT="%(asctime)s - %(name)s - %(levelname)s - %(message)s"
LOG_FILE=./logs/chaksudb.log


# ============================================
# Notes
# ============================================
# All values are optional - defaults are provided in config.py
# Uncomment and modify values as needed for your environment
